# ─────────────────────────────────────────────────────────────────────────────
# Applaud-Assistant configuration. Copy to `.env` and fill in.
# ─────────────────────────────────────────────────────────────────────────────

# --- App / single-user auth ----------------------------------------------------
# The one account that can log into the UI/API.
APP_USERNAME=admin
# Use a long random string. You can generate one with: openssl rand -hex 32
APP_PASSWORD=change-me
# Secret used to sign session/JWT tokens. openssl rand -hex 32
AUTH_SECRET=change-me-too

# --- Ports ---------------------------------------------------------------------
WEB_PORT=3000
SYNC_PORT=8080
PROCESSING_PORT=8000

# --- Storage -------------------------------------------------------------------
# Where mirrored audio + derived data live on the host (bind-mounted into containers).
DATA_DIR=./data

# --- Plaud mirror --------------------------------------------------------------
# Plaud's web API is undocumented. The bearer token is read from your logged-in
# browser session (see docs/SETUP.md). Paste it here or let the sync service
# extract it. Leave blank to configure via the UI setup wizard.
PLAUD_BEARER_TOKEN=
# How often to poll Plaud for new recordings (seconds).
PLAUD_POLL_INTERVAL=600

# --- Webhooks (optional) -------------------------------------------------------
# Comma-separated URLs notified on audio_ready / transcript_ready.
WEBHOOK_URLS=

# --- Processing (Whisper) ------------------------------------------------------
# auto | cpu | cuda | mps
WHISPER_DEVICE=auto
# e.g. openai/whisper-large-v3, distil-whisper/distil-large-v3
WHISPER_MODEL=openai/whisper-large-v3

# --- LLM analysis --------------------------------------------------------------
# Default provider for "analyze": ollama | openai | anthropic | gemini | openrouter
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1
OLLAMA_BASE_URL=http://ollama:11434
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# --- Google Drive archive (OAuth user account) ---------------------------------
# OAuth client (Desktop app) credentials from Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Folder name created in your My Drive to hold archives.
GDRIVE_ARCHIVE_FOLDER=Applaud-Assistant Archive
# Set true to archive automatically as soon as a recording is fully mirrored.
GDRIVE_AUTO_ARCHIVE=true
